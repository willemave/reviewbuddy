# Search provider override: exa, tavily, or firecrawl
# Leave unset to auto-select from any configured provider key.
# ReviewBuddy also auto-loads provider keys from ~/.hermes/.env and ~/.openclaw/openclaw.json.
SEARCH_PROVIDER=
SEARCH_NUM_RESULTS=30
SEARCH_MIN_RESULTS_PER_QUERY=20

# Exa
EXA_API_KEY=
EXA_SEARCH_TYPE=auto
EXA_USER_LOCATION=US

# Tavily
TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=basic
TAVILY_TOPIC=general
TAVILY_AUTO_PARAMETERS=false

# Firecrawl
FIRECRAWL_API_KEY=
FIRECRAWL_COUNTRY=US
FIRECRAWL_LOCATION=United States

# Optional integrations
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
